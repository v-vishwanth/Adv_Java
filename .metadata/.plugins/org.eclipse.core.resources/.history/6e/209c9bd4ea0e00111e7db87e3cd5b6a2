package com.lpu.interfaceReferance;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;

public class person {
	@Value("101")
	private int id;
	@Value("Donkey")
	private String name;
	@Autowired
	private vehicle v;
	public int getId() {
		return id;
	}
	public String getName() {
		return name;
	}
